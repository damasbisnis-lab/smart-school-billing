# =====================================================
# KONFIGURASI SUPABASE
# =====================================================
# 1. Buat akun di https://supabase.com (Gratis)
# 2. Buat project baru
# 3. Copy URL dan Anon Key dari Project Settings > API
# =====================================================

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# =====================================================
# CATATAN PENTING:
# =====================================================
# - File .env ini TIDAK boleh di-commit ke repository
# - Copy file ini menjadi .env.local untuk development
# - Untuk production, masukkan environment variables 
#   langsung di dashboard Vercel
# =====================================================
